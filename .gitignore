# Obsidian plugin/theme runtime files
.obsidian/plugins/*/main.js
.obsidian/plugins/*/styles.css
.obsidian/plugins/*/data.json
.obsidian/themes/*/theme.css

# Raw, generated, bulky, or non-canonical areas
attachments/
_RAW/
_OUTPUTS/
_COMPILED_WIKI/
archive/
